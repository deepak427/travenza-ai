# Google Cloud Project ID
PROJECT_ID=your-project-id
# Google Cloud Location
LOCATION=us-central1
# Gemini Model
MODEL=gemini-live-2.5-flash-native-audio
# Session time limit in seconds
SESSION_TIME_LIMIT=300
# Development Mode (true = no rate limiting, no recaptcha)
DEV_MODE=true
# Optional: Redis URL for rate limiting in production
# REDIS_URL=redis://...
# Optional: ReCAPTCHA site key
# RECAPTCHA_SITE_KEY=your-key
# Optional: BigQuery tracking
# BQ_DATASET=your-dataset
# BQ_TABLE=your-table
# App name for tracking
DEMO_NAME=travenza-ai
